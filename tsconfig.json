{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"lib": [
			"DOM",
			"ES5",
			"ES6",
			"ES7"
		],
		"allowSyntheticDefaultImports": true
	},
	"include": [
		"src",
		"**/*.ts",
		"vite.config.mts"
	]
}
